---
import { ACQUISITION_MAILTO, CF_IMAGES } from '../config/site';
import AcquisitionCTA from './AcquisitionCTA.astro';
import CloudflareImage from './CloudflareImage.astro';
---

<header class="domain-hero text-white relative overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <CloudflareImage
      src={CF_IMAGES.hero}
      alt=""
      width={1920}
      height={1080}
      loading="eager"
      fetchpriority="high"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/90 via-slate-900/80 to-indigo-950/70"></div>

  <div class="relative max-w-screen-2xl mx-auto px-8 pt-16 pb-20 md:pt-20 md:pb-24">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-8">
        <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
        <span class="text-xs font-semibold tracking-widest uppercase">Premium Strategic Asset • Available Now</span>
      </div>

      <h1 class="text-6xl md:text-7xl font-display tracking-tighter leading-none mb-6">
        PHX<span class="text-indigo-400">.</span>Contact
      </h1>

      <p class="max-w-2xl text-2xl md:text-3xl font-light text-white/90 tracking-tight mb-10 leading-tight">
        The ultra-short, brandable domain that owns <span class="font-medium text-white">Phoenix contact</span>.
      </p>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <AcquisitionCTA variant="primary" size="lg" label="Secure This Domain" />
        <a
          href="#why"
          class="inline-flex items-center justify-center gap-x-2 px-7 py-4 text-base font-medium border border-white/30 hover:bg-white/10 text-white rounded-3xl transition-all"
        >
          <span>Why it commands value</span>
        </a>
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
        <div class="text-white/70 text-xs font-medium tracking-wider">
          SERIOUS INQUIRIES FROM TECH, REAL ESTATE &amp; LOCAL BRANDS
        </div>
        <a
          href={ACQUISITION_MAILTO}
          class="text-xs font-semibold text-indigo-300 hover:text-white transition-colors"
        >
          sales@desertrich.com →
        </a>
      </div>
    </div>
  </div>
</header>
