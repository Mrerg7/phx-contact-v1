---
import { ACQUISITION_MAILTO, SITE } from '../config/site';

interface Props {
  variant?: 'primary' | 'secondary' | 'light' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  label?: string;
}

const {
  variant = 'primary',
  size = 'md',
  class: className = '',
  label = 'Inquire About phx.contact',
} = Astro.props;

const sizeClasses = {
  sm: 'px-5 py-2.5 text-sm',
  md: 'px-9 py-4 text-base',
  lg: 'px-10 py-[17px] text-lg',
};

const variantClasses = {
  primary:
    'conversion-cta bg-indigo-600 hover:bg-indigo-500 active:bg-indigo-700 text-white font-semibold shadow-xl shadow-indigo-900/30',
  secondary:
    'border border-white/30 hover:bg-white/10 text-white font-medium',
  light:
    'conversion-cta bg-white text-slate-950 hover:bg-indigo-100 active:bg-white font-semibold shadow-2xl',
  outline:
    'border border-slate-300 hover:bg-slate-50 text-slate-900 font-semibold',
};

const classes = [
  'inline-flex items-center justify-center gap-x-3 rounded-3xl transition-all active:scale-[0.985]',
  sizeClasses[size],
  variantClasses[variant],
  className,
]
  .filter(Boolean)
  .join(' ');
---

<a href={ACQUISITION_MAILTO} class={classes} aria-label={`${label} — email ${SITE.email}`}>
  <span>{label}</span>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
  </svg>
</a>
