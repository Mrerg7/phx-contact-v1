---
import BaseLayout from '../layouts/BaseLayout.astro';
import AcquisitionCTA from '../components/AcquisitionCTA.astro';
---

<BaseLayout
  title="404 — Page Not Found | phx.contact"
  description="The page you were looking for could not be found."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center px-8 domain-hero text-white">
    <div class="text-center max-w-md">
      <div class="text-8xl font-display font-bold text-indigo-400 mb-4">404</div>
      <h1 class="text-2xl font-display font-semibold mb-3">Page Not Found</h1>
      <p class="text-white/70 mb-8">
        The page you're looking for doesn't exist. Perhaps you're interested in acquiring the domain instead?
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-x-2 px-8 py-3 border border-white/30 hover:bg-white/10 text-white font-semibold rounded-3xl transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          Back to phx.contact
        </a>
        <AcquisitionCTA variant="primary" size="sm" label="Inquire About Acquisition" />
      </div>
    </div>
  </main>
</BaseLayout>
