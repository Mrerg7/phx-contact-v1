---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import CloudflareImage from '../components/CloudflareImage.astro';
import AcquisitionCTA from '../components/AcquisitionCTA.astro';
import Footer from '../components/Footer.astro';
import { CF_IMAGES } from '../config/site';

const sortByOrder = <T extends { data: { order: number } }>(items: T[]) =>
  items.sort((a, b) => a.data.order - b.data.order);

const sortByStep = <T extends { data: { step: number } }>(items: T[]) =>
  items.sort((a, b) => a.data.step - b.data.step);

const [valuePillars, opportunityPaths, marketStats, strategicValues, acquisitionSteps] =
  await Promise.all([
    getCollection('value-pillars'),
    getCollection('opportunity-paths'),
    getCollection('market-stats'),
    getCollection('strategic-values'),
    getCollection('acquisition-steps'),
  ]);

const iconPaths: Record<string, string> = {
  bolt: 'M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z',
  bullseye: 'M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z',
  'map-marker': 'M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z',
  globe: 'M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.512 5.73 6.974 6 7.5 6A1.5 1.5 0 019 7.5V8a2 2 0 004 0 2 2 0 011.523-1.943A5.977 5.977 0 0116 10c0 .34-.028.675-.083 1H15a2 2 0 00-2 2v2.197A5.973 5.973 0 0110 16v-2a2 2 0 00-2-2 2 2 0 01-2-2 2 2 0 00-1.668-1.973z',
  briefcase: 'M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4zm0 5v7a2 2 0 002 2h12a2 2 0 002-2V9H4zm4 2a1 1 0 011-1h6a1 1 0 110 2H9a1 1 0 01-1-1z',
};
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <TrustBar />

    <!-- Visual break -->
    <section class="bg-white border-b border-slate-200">
      <div class="max-w-screen-2xl mx-auto px-8 py-12 md:py-16">
        <div class="rounded-3xl overflow-hidden border border-slate-200 ring-1 ring-slate-100">
          <CloudflareImage
            src={CF_IMAGES.secondary}
            alt="Phoenix, Arizona — premium local market for PHX.Contact domain acquisition"
            width={1920}
            height={800}
            class="w-full h-auto object-cover aspect-[21/9]"
          />
        </div>
      </div>
    </section>

    <!-- Why This Domain -->
    <section id="why" class="max-w-screen-2xl mx-auto px-8 pt-16 pb-12">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <div class="inline-block px-4 py-1 rounded-2xl bg-indigo-100 text-indigo-700 text-xs font-bold tracking-[1.5px] mb-4">
          WHY THIS IS A RARE STRATEGIC ASSET
        </div>
        <h2 class="section-header tracking-tighter">
          Ultra-short. Exact-match intent.<br />Instant Phoenix authority.
        </h2>
        <p class="mt-4 text-xl text-slate-600">
          PHX.Contact combines the most recognized shorthand for Phoenix with a purpose-built TLD. Very few domains offer this level of brand clarity and category relevance.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 max-w-7xl mx-auto">
        {sortByOrder(valuePillars).map((entry) => (
          <div class="modern-card bg-white border border-slate-200 rounded-3xl p-7">
            <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${entry.data.gradient} flex items-center justify-center mb-6`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d={iconPaths[entry.data.icon]} clip-rule="evenodd" />
              </svg>
            </div>
            <h3 class="font-semibold text-xl tracking-tight mb-3">{entry.data.title}</h3>
            <p class="text-slate-600 leading-relaxed">{entry.data.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Opportunity -->
    <section id="opportunity" class="bg-white border-y border-slate-200 py-16">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <div class="inline-block px-4 py-1 rounded-2xl bg-emerald-100 text-emerald-700 text-xs font-bold tracking-[1.5px] mb-4">
            A COHESIVE HIGH-VALUE VISION
          </div>
          <h2 class="section-header tracking-tighter">
            One premium domain.<br />Multiple high-impact paths.
          </h2>
          <p class="mt-4 text-xl text-slate-600 max-w-md mx-auto">
            PHX.Contact is perfectly positioned for both <span class="font-semibold text-slate-900">building a local platform</span> and <span class="font-semibold text-slate-900">premium branding</span> in Phoenix's growing digital economy.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-6 max-w-6xl mx-auto">
          {sortByOrder(opportunityPaths).map((entry) => (
            <div class="group border border-slate-200 rounded-3xl p-9 bg-slate-50 hover:border-indigo-200 transition-colors flex flex-col">
              <div class="flex items-center gap-x-4 mb-6">
                <div class={`use-case-icon ${entry.data.order === 2 ? 'bg-gradient-to-br from-indigo-500 to-indigo-600 text-white' : ''}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d={iconPaths[entry.data.icon]} clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="px-3 py-1 text-xs font-bold tracking-widest bg-white border border-slate-200 rounded-2xl">
                  {entry.data.path}
                </span>
              </div>

              <h3 class="font-display text-3xl tracking-tighter mb-4">{entry.data.title}</h3>
              <p class="text-slate-600 mb-8 leading-relaxed">{entry.data.description}</p>

              <div class="mt-auto">
                <div class="text-xs font-bold tracking-widest text-slate-500 mb-3">
                  {entry.data.tagStyle === 'pills' ? 'IDEAL FOR' : 'PERFECT FOR'}
                </div>
                {entry.data.tagStyle === 'pills' ? (
                  <div class="flex flex-wrap gap-2">
                    {entry.data.tags.map((tag) => (
                      <span class="px-4 py-1.5 text-xs font-medium bg-white border border-slate-200 rounded-2xl">{tag}</span>
                    ))}
                  </div>
                ) : (
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
                    {entry.data.tags.map((tag) => (
                      <div class="flex items-center gap-x-2 text-slate-700">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        <span>{tag}</span>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Market Context -->
    <section class="max-w-screen-2xl mx-auto px-8 py-16">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-12 gap-x-12 items-center">
          <div class="md:col-span-5">
            <div class="sticky top-24">
              <div class="text-xs font-bold tracking-[2px] text-indigo-600 mb-3">THE PHOENIX ADVANTAGE</div>
              <h2 class="section-header tracking-tighter leading-none">
                One of America's fastest-growing major metros with exploding demand for local digital infrastructure.
              </h2>
              <p class="mt-6 text-lg text-slate-600">
                Phoenix continues rapid population and business growth. Companies and professionals increasingly need sophisticated local contact, lead, and relationship tools — exactly what PHX.Contact is built to own.
              </p>
            </div>
          </div>

          <div class="md:col-span-7 mt-10 md:mt-0">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {sortByOrder(marketStats).map((stat) => (
                <div class="value-pill rounded-3xl p-6">
                  <div class="text-indigo-600 text-xs font-bold tracking-widest">{stat.data.label}</div>
                  <div class="mt-3 text-4xl font-semibold tracking-tighter">{stat.data.value}</div>
                  <div class="text-sm text-slate-600 mt-1">{stat.data.description}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Strategic Value -->
    <section id="value" class="bg-slate-900 text-white py-16">
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <div class="text-indigo-400 text-xs font-bold tracking-[2.5px]">PREMIUM STRATEGIC ASSET CHARACTERISTICS</div>
          <h2 class="section-header tracking-tighter mt-3 text-white">Why PHX.Contact commands exceptional value</h2>
        </div>

        <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
          {sortByOrder(strategicValues).map((item) => (
            <div class="bg-white/5 border border-white/10 rounded-3xl p-8">
              <div class="font-mono text-5xl font-semibold tracking-tighter text-white mb-1">{item.data.value}</div>
              <div class="text-lg font-medium">{item.data.label}</div>
              <div class="mt-4 text-sm text-white/70">{item.data.description}</div>
            </div>
          ))}
        </div>

        <div class="max-w-4xl mx-auto mt-12 text-center">
          <p class="text-white/70 text-sm max-w-lg mx-auto">
            Short, meaningful geo + keyword new TLD combinations of this quality are exceptionally rare. PHX.Contact represents a high-value strategic asset suitable for serious buyers, investors, or companies building meaningful local infrastructure in one of America's top growth markets.
          </p>

          <div class="mt-8 inline-flex items-center gap-x-2 text-xs px-5 py-3 bg-white/5 border border-white/10 rounded-3xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <span class="font-medium">Premium acquisition. All serious offers considered. Escrow recommended.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- How to Acquire -->
    <section class="max-w-screen-2xl mx-auto px-8 py-20">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <div class="inline px-4 py-1 text-xs font-bold tracking-widest bg-slate-100 text-slate-600 rounded-2xl">
            PREMIUM ACQUISITION PROCESS
          </div>
          <h2 class="section-header tracking-tighter mt-4">Simple, secure, and confidential</h2>
        </div>

        <div class="space-y-5">
          {sortByStep(acquisitionSteps).map((step) => (
            <div class="flex gap-6 bg-white border border-slate-200 rounded-3xl p-8 items-start">
              <div class="w-9 h-9 flex-shrink-0 rounded-2xl bg-slate-900 text-white flex items-center justify-center font-mono font-bold text-xl">
                {step.data.step}
              </div>
              <div class="flex-1 pt-1">
                <div class="font-semibold text-xl tracking-tight">{step.data.title}</div>
                <div class="text-slate-600 mt-1.5">{step.data.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <div class="bg-gradient-to-br from-slate-900 via-slate-950 to-black py-16 text-white">
      <div class="max-w-screen-2xl mx-auto px-8 text-center">
        <div class="max-w-lg mx-auto">
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl tracking-tighter">Ready to own PHX.Contact?</h2>
          <p class="mt-4 text-white/70">
            This is a rare, high-value strategic asset in one of America's most dynamic growth markets. Serious inquiries only.
          </p>

          <div class="mt-9">
            <AcquisitionCTA variant="light" size="lg" label="Submit Confidential Offer" class="w-full sm:w-auto" />
          </div>

          <div class="mt-5 text-xs text-white/50">Confidential • Qualified buyers only • Response within 24 hours</div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
