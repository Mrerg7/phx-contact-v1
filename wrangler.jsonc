{
	"$schema": "node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-07-02",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "phx-contact-v1",
	"workers_dev": false,
	"preview_urls": false,
	"assets": {
		"directory": "./dist",
		"not_found_handling": "404-page"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "phx.contact", "custom_domain": true },
		{ "pattern": "www.phx.contact", "custom_domain": true }
	]
}
